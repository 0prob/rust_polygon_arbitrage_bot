# polarb-rust environment variables
# Copy to .env and fill in your values. Loaded automatically at startup.
# Set DOTENV_PATH to use a file outside the working directory.
#
# Alternatively, set CONFIG_PATH to a TOML file (merged on top of env vars).
#
# Env naming: flat keys below match the TypeScript bot (/home/x/arb/t/.env.example).
# Nested Figment keys also work (e.g. EXECUTION__MODE, ROUTING__MAX_HOPS).

# Dedicated RPC Providers (Recommended for Production):
# For high-volume, high-throughput, or commercial applications, dedicated node
# infrastructure prevents rate-limiting issues. Popular providers include:
# QuickNode: Offers enterprise-grade dedicated endpoints for mainnet and testnets.
# Chainstack: Highly recommended for DeFi, payment applications, and enterprise infrastructure.
# Alchemy: Excellent developer platform with extensive analytics.
# dRPC: A decentralized RPC aggregator that minimizes single points of failure.
# Ankr: Provides instant RPC endpoints for realistic testing environments.

# ─── Required for live execution ─────────────────────────────────────────────

# Wallet private key for signing transactions (0x + 64 hex chars)
PRIVATE_KEY=your_private_key

# Deployed Huff ArbExecutor contract address (see "Huff executor deploy" below)
EXECUTOR_ADDRESS=0xYourExecutorAddress

# RPC endpoint for tx submission, gas queries, and dry-run simulation
EXECUTION_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── RPC (pool state reads) ──────────────────────────────────────────────────

# Archival RPC for multicall pool-state refresh (recommended separate from execution RPC)
STATE_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Comma-separated Polygon RPC URLs (fallback when STATE_RPC_URL is unset)
POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY,https://polygon-rpc.com

# Single URL alternative to POLYGON_RPC_URLS
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# HyperSync endpoint override (optional; defaults to polygon.hypersync.xyz)
# RPC__HYPER_SYNC_URL=https://polygon.hypersync.xyz

# ─── Indexer (HyperIndex + Hasura) ───────────────────────────────────────────

# Hasura GraphQL endpoint for Envio pool discovery
HASURA_URL=http://localhost:8080/v1/graphql

# Hasura admin secret (must match hyperindex config)
HASURA_SECRET=testing

# ─── HyperSync ───────────────────────────────────────────────────────────────

# Envio API token — enables HyperSync head feed and receipt lookups
ENVIO_API_TOKEN=your_envio_token_here

# ─── Execution ───────────────────────────────────────────────────────────────

# dry-run | live
EXECUTION_MODE=dry-run

# Minimum net profit in wei after flash-loan fees
MIN_PROFIT_WEI=100000000000000000

# Slippage tolerance in basis points
SLIPPAGE_BPS=50

# Flash loan provider: auto | BALANCER | AAVE_V3
# auto = Balancer-first waterfall at dispatch (Aave fallback, then cap+re-optimize)
FLASH_LOAN_SOURCE=auto

# Receipt wait timeout / poll interval (milliseconds)
RECEIPT_TIMEOUT_MS=30000
RECEIPT_POLL_MS=500

# ─── Routing ─────────────────────────────────────────────────────────────────

# Maximum hops in arbitrage cycle search
ROUTING_MAX_HOPS=5

# Ternary search iterations for input sizing
TERNARY_SEARCH_ITERATIONS=12

# Maximum cycle paths to enumerate per LF tick
ROUTING_ENUMERATION_MAX_PATHS=5000

# Cycle finder: dfs | bellman-ford
ROUTING_CYCLE_FINDER=bellman-ford

# ─── Pass intervals ──────────────────────────────────────────────────────────

# LF graph/cycle pass interval (ms)
LF_INTERVAL_MS=1000

# HF optimize/execute pass interval (ms)
HF_INTERVAL_MS=200

# Hasura pool discovery refresh interval (ms)
DISCOVERY_INTERVAL_MS=60000

# ─── Oracle (token → MATIC rates) ────────────────────────────────────────────

# Enable Chainlink + Pyth enrichment for HF profit scoring
ORACLE_ENABLED=true

# Pyth Hermes HTTP endpoint for MATIC-denominated token prices
ORACLE_PYTH_HERMES_URL=https://hermes.pyth.network

# V3 TickLens: tick words fetched on each side of current tick
TICK_WORD_RANGE=4

# ─── Optional overrides ────────────────────────────────────────────────────────

# Path to config.toml (merged on top of env vars)
# CONFIG_PATH=./config.toml

# CHAIN_ID=137
# MAX_MULTICALL_CALLS=800
# RPC__REQUEST_TIMEOUT_MS=8000
# RPC__BATCH_WAIT_MS=16
# RPC__BATCH_SIZE=100

# ─── Huff executor deploy (../t/sol) ─────────────────────────────────────────
#
# Contract: ArbExecutor.huff — flash-loan-only executor used by calldata encoding.
# Calldata parity tests in tests/calldata_parity.rs match TS fixtures and Huff selectors:
#   executeArb          0x491e69d3
#   executeArbWithAave  0xb8efd6fe
#   approveIfNeeded     0xfad6b994
#   transferAll         0x4b14e003
#
# Redeploy from repo root:
#   ./scripts/deploy-executor.sh
# Then set EXECUTOR_ADDRESS above to the logged address.
#
# Deployer wallet address (must match PRIVATE_KEY; becomes Huff contract owner)
OWNER=0xYourDeployerAddress

# Polygon mainnet defaults (override only when factories/vault change)
# BALANCER_VAULT=0xBA12222222228d8Ba445958a75a0704d566BF2C8
# UNISWAP_V3_FACTORY=0x1F98431c8aD98523631AE4a59f267346ea31F984
# SUSHISWAP_V3_FACTORY=0x917933899c6a5F8E37F31E19f92CdBFF7e8FF0e2
# QUICKSWAP_V3_FACTORY=0x411b0fAcC3489691f28ad58c47006AF5E3Ab3A28
# KYBER_ELASTIC_FACTORY=0x5F1dddbf348aC2fbe22a163e30F99F9ECE3DD50a
# RAMSES_V3_FACTORY=0x2Bef16A0081565E72100D73CBe19B1Bd2d802380
# AAVE_POOL=0x794a61358D6845594F94dc1DB02A252b5b4814aD
# POOL_MANAGER=0x67366782805870060151383F4BbFF9daB53e5cD6

# ─── Observability ───────────────────────────────────────────────────────────

# Log filter (tracing): info | debug | c=debug | c::orchestrator=trace,...
RUST_LOG=info

# Structured JSON logs to stderr (default: human-readable)
# TRACING_JSON=1

# Enable tokio-console task introspection (requires compile-time RUSTFLAGS below)
# TOKIO_CONSOLE=1
# RUSTFLAGS='--cfg tokio_unstable'

# ─── Profiling & macro debugging ─────────────────────────────────────────────
#
# Flamegraphs (install: cargo install flamegraph):
#   cargo flamegraph --bin flame_profile -- routing
#   cargo flamegraph --bin flame_profile -- price
#   cargo flamegraph --bin flame_profile -- math
#   cargo flamegraph --bin flame_profile -- all
#
# tokio-console (build with feature + RUSTFLAGS, then set TOKIO_CONSOLE=1):
#   RUSTFLAGS='--cfg tokio_unstable' cargo build --features tokio-console --release
#   cargo install tokio-console
#   tokio-console
#
# Expand Alloy sol! macros (install: cargo install cargo-expand):
#   cargo expand --lib abis
